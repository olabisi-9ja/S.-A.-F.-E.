{
  "cli": {
    "version": ">= 7.0.0",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REPLACE_WITH_PUBLIC_BACKEND_URL"
      }
    },
    "apk": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REPLACE_WITH_PUBLIC_BACKEND_URL"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REPLACE_WITH_PUBLIC_BACKEND_URL"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
